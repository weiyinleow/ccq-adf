{
	"name": "DS_SNK_Filesystem_ADSL_Generic_MSATS",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LS_ADLS2_Landing",
			"type": "LinkedServiceReference",
			"parameters": {
				"ls_param_endpoint": {
					"value": "@dataset().ds_param_endPoint",
					"type": "Expression"
				}
			}
		},
		"parameters": {
			"ds_param_endPoint": {
				"type": "string",
				"defaultValue": "https://cqldevdatahubdata.dfs.core.windows.net"
			},
			"ds_param_archive_path": {
				"type": "string",
				"defaultValue": "2023/10-oct/02"
			}
		},
		"folder": {
			"name": "2b - Datalake"
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"folderPath": {
					"value": "@if(equals(dataset().ds_param_archive_path,'yyyy/mm-mmm/dd'),\nconcat('AEMO_MSATS_zip', '/',formatDateTime(utcnow(), 'yyyy'), '/',formatDateTime(utcnow(),'MM'),'-',toLower(formatDateTime(utcnow(),'MMM')),'/',formatDateTime(utcnow(),'dd')), concat('AEMO_MSATS_zip', '/',dataset().ds_param_archive_path))\n",
					"type": "Expression"
				},
				"fileSystem": "drop-zone"
			}
		}
	}
}