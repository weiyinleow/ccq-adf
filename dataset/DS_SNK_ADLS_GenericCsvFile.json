			"parameters": {
				"ls_param_endpoint": {
					"value": "@dataset().ds_param_endPoint",
					"type": "Expression"
				}
			}
		},
		"parameters": {
			"ds_param_endPoint": {
				"type": "string",
				"defaultValue": "https://vndatapltfv2devst02.dfs.core.windows.net"
			},
			"ds_param_folder": {
				"type": "string"
			},
			"ds_param_fileName": {
				"type": "string"
			},
			"ds_param_fileSystem": {
				"type": "string",
				"defaultValue": "landing"
			}
