					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderStoredProcedureName": "[CTL].[USP_GET_SOURCE_CONFIG]",
						"storedProcedureParameters": {
							"TOKEN": {
								"type": "String",
								"value": {
									"value": "@pipeline().parameters.pl_param_loadToken",
									"type": "Expression"
								}
							}
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "DS_CFG_SQL_DeltaValuesTable",
						"type": "DatasetReference"
					}
				}
			},
			{
				"name": "alertOnStart",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "logPipelineRunning",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "PL_ALERT_ON_START",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"pl_param_pipelineConfig": {
							"value": "@activity('getPipelineConfig').output.firstRow",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "alertOnCompletion",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "logPipelineCompletion",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "PL_ALERT_ON_COMPLETE",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
