					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[CTL].[USP_LOG_PIPELINE_RUNNING]",
					"storedProcedureParameters": {
						"PIPELINE_ID": {
							"value": {
								"value": "@activity('getPipelineConfig').output.firstRow.PIPELINE_ID",
								"type": "Expression"
							},
							"type": "Int32"
						},
						"PIPELINE_NAME": {
							"value": {
								"value": "@activity('getPipelineConfig').output.firstRow.PIPELINE_NAME",
								"type": "Expression"
							},
							"type": "String"
						},
						"RUN_ID": {
							"value": {
								"value": "@pipeline().RunId",
								"type": "Expression"
							},
							"type": "Guid"
						},
						"START_DATETIME": {
							"value": {
								"value": "@pipeline().TriggerTime",
								"type": "Expression"
							},
							"type": "Datetime"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "LS_SQL_ELTFrameworkDB",
					"type": "LinkedServiceReference"
				}
			},
			{
