						"pl_param_pipelineConfig": {
							"value": "@activity('getPipelineConfig').output.firstRow",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "ForEachLoadItemSrcToLnd",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "alertOnStart",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('getLoadSetItems').output.value",
						"type": "Expression"
					},
					"batchCount": 10,
					"activities": [
						{
							"name": "switchOnIngestStages",
							"type": "Switch",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"on": {
									"value": "@if(activity('getloadSet').output.firstRow.ENABLED,activity('getloadSet').output.firstRow.INGEST_STAGES,'notEnabled')",
									"type": "Expression"
								},
								"cases": [
									{
										"value": "srcToStoreViaLanding",
										"activities": [
											{
												"name": "execWorkerSelectionSrcToStoreViaLnd",
												"type": "ExecutePipeline",
												"dependsOn": [],
												"policy": {
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"pipeline": {
														"referenceName": "PL_INGEST_WORKER_SELECTION_SRC_TO_STORE_VIA_LND",
														"type": "PipelineReference"
													},
													"waitOnCompletion": true,
													"parameters": {
														"pl_param_pipelineId": {
															"value": "@activity('getPipelineConfig').output.firstRow.PIPELINE_ID",
															"type": "Expression"
														},
														"pl_param_pipelineRunId": {
															"value": "@pipeline().RunId",
															"type": "Expression"
														},
														"pl_param_sourceConfig": {
															"value": "@activity('getSourceConfig').output.firstRow",
															"type": "Expression"
														},
														"pl_param_loadItem": {
															"value": "@item()",
															"type": "Expression"
														},
														"pl_param_loadConfig": {
															"value": "@activity('getloadSet').output.firstRow",
															"type": "Expression"
														},
														"pl_param_destinationConfig": {
															"value": "@activity('getDestinationConfig').output.firstRow",
															"type": "Expression"
														}
													}
												}
											}
										]
									},
									{
										"value": "srcToStoreDirect",
										"activities": [
											{
												"name": "execWorkerSelectionSrcToStoreDirect",
												"type": "ExecutePipeline",
												"dependsOn": [],
												"policy": {
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"pipeline": {
														"referenceName": "PL_INGEST_WORKER_SELECTION_SRC_TO_STORE_DIRECT",
														"type": "PipelineReference"
													},
													"waitOnCompletion": true,
													"parameters": {
														"pl_param_pipelineId": {
															"value": "@activity('getPipelineConfig').output.firstRow.PIPELINE_ID",
															"type": "Expression"
														},
														"pl_param_pipelineRunId": {
															"value": "@pipeline().RunId",
															"type": "Expression"
														},
														"pl_param_sourceConfig": {
															"value": "@activity('getSourceConfig').output.firstRow",
															"type": "Expression"
														},
														"pl_param_loadItem": {
															"value": "@item()",
															"type": "Expression"
														},
														"pl_param_loadConfig": {
															"value": "@activity('getloadSet').output.firstRow",
															"type": "Expression"
														},
														"pl_param_destinationConfig": {
															"value": "@activity('getDestinationConfig').output.firstRow",
															"type": "Expression"
														}
													}
												}
											}
										]
									},
									{
										"value": "lndToStore",
										"activities": [
											{
												"name": "execWorkerSelectionLndToStore",
												"type": "ExecutePipeline",
												"dependsOn": [],
												"policy": {
													"secureInput": false
												},
												"userProperties": [],
												"typeProperties": {
													"pipeline": {
														"referenceName": "PL_INGEST_WORKER_SELECTION_LND_TO_STORE",
														"type": "PipelineReference"
													},
													"waitOnCompletion": true,
													"parameters": {
														"pl_param_pipelineId": {
															"value": "@activity('getPipelineConfig').output.firstRow.PIPELINE_ID",
															"type": "Expression"
														},
														"pl_param_pipelineRunId": {
															"value": "@pipeline().RunId",
															"type": "Expression"
														},
														"pl_param_sourceConfig": {
															"value": "@activity('getSourceConfig').output.firstRow",
															"type": "Expression"
														},
														"pl_param_loadItem": {
															"value": "@item()",
															"type": "Expression"
														},
														"pl_param_loadConfig": {
															"value": "@activity('getloadSet').output.firstRow",
															"type": "Expression"
														},
														"pl_param_destinationConfig": {
															"value": "@activity('getDestinationConfig').output.firstRow",
															"type": "Expression"
														}
													}
												}
											}
										]
									}
								]
							}
						}
					]
				}
			},
