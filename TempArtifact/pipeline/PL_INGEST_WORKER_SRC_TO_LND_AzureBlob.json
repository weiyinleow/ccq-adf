												"loadset_id": {
													"type": "Int32",
													"value": {
														"value": "@pipeline().parameters.pl_param_loadConfig.LOADSET_ID",
														"type": "Expression"
													}
												},
												"loadset_item_id": {
													"type": "Int32",
													"value": {
														"value": "@pipeline().parameters.pl_param_item.LOADSET_ITEM_ID",
														"type": "Expression"
													}
												},
												"source_type": {
													"type": "String",
													"value": {
														"value": "@pipeline().parameters.pl_param_item.SOURCE_TYPE",
														"type": "Expression"
													}
												}
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"dataset": {
											"referenceName": "DS_CFG_SQL_DeltaValuesTable",
											"type": "DatasetReference"
										}
									}
								},
								{
									"name": "IntializeVarMaxDeltaValue",
									"type": "SetVariable",
									"dependsOn": [
										{
											"activity": "setVarMinDeltaValue",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"variableName": "maxDeltaValue",
										"value": {
											"value": "@variables('minDeltaValue')",
											"type": "Expression"
										}
									}
								}
							]
						}
					],
					"defaultActivities": [
						{
							"name": "IntializeVarMaxDeltaValue_minus30",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "IntializeVarMinDeltaValue_minus30",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "maxDeltaValue",
								"value": {
									"value": "@variables('minDeltaValue')",
									"type": "Expression"
								}
							}
						},
						{
							"name": "IntializeVarMinDeltaValue_minus30",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "minDeltaValue",
								"value": {
									"value": "@adddays(utcNow(),-30,'yyyy-MM-dd')",
									"type": "Expression"
								}
							}
						}
					]
				}
			},
			{
				"name": "GetFileList",
