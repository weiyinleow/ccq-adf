				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "SourceFolderPath",
					"value": {
						"value": "@concat(\n  'pd-app/',\n  replace(pipeline().parameters.usecase, ' ', '_'), '/',\n  replace(pipeline().parameters.user, ' ', '_'), '/',\n  variables('pipeline_time')\n)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "ArchiveFolderPath",
				"description": "Creates a folder path based on UTC time to be shared by all files being archived.",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Set variable FolderTimeString",
						"dependencyConditions": [
							"Succeeded"
						]
