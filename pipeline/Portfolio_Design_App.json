				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "ArchiveFolderPath",
					"value": {
						"value": "@concat(\n  'portfolio-design/pd-app/',\n  replace(pipeline().parameters.usecase, ' ', '_'), '/',\n  replace(pipeline().parameters.user, ' ', '_'), '/',\n  variables('vFolderTimeString')\n)",
						"type": "Expression"
					}
				}
