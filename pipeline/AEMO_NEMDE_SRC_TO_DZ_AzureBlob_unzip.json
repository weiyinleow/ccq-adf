{
	"name": "AEMO_NEMDE_SRC_TO_DZ_AzureBlob_unzip",
	"properties": {
		"activities": [
			{
				"name": "AEMO_NEMDE_FileCopy_unzip",
				"description": "NEMDE files unzip",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "BinarySource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true
						},
						"formatSettings": {
							"type": "BinaryReadSettings",
							"compressionProperties": {
								"type": "ZipDeflateReadSettings"
							}
						}
					},
					"sink": {
						"type": "BinarySink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings",
							"copyBehavior": "PreserveHierarchy"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "DS_SNK_Filesystem_ADSL_Generic_source_NEMDE",
						"type": "DatasetReference",
						"parameters": {
							"ds_param_endPoint": {
								"value": "@pipeline().globalParameters.param_dz_storage_endpoint",
								"type": "Expression"
							},
							"ds_param_folder": "drop-zone",
							"ds_param_path": "AEMO_NEMDE_zip"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_SNK_Filesystem_ADSL_Generic_destination_NEMDE",
						"type": "DatasetReference",
						"parameters": {
							"ds_param_endPoint": {
								"value": "@pipeline().globalParameters.param_dz_storage_endpoint",
								"type": "Expression"
							},
							"ds_param_folder": "drop-zone",
							"ds_param_path": "AEMO_NEMDE_SourceCopy"
						}
					}
				]
			}
		],
		"folder": {
			"name": "2 - DataHubPipelines/AEMONEMDE/SubPipelines"
		},
		"annotations": []
	}
}